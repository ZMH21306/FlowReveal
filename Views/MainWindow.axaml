<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlowReveal.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="FlowReveal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FlowReveal - Network Packet Analyzer"
        Width="1200" Height="800"
        MinWidth="800" MinHeight="600">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <DockPanel>
        <!-- Toolbar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="8,8,8,4">
            <Button Content="Start Capture" Command="{Binding StartCaptureCommand}" IsEnabled="{Binding !IsCapturing}" MinWidth="100"/>
            <Button Content="Stop Capture" Command="{Binding StopCaptureCommand}" IsEnabled="{Binding IsCapturing}" MinWidth="100"/>
            <Separator/>
            <Button Content="Clear" Command="{Binding ClearCommand}" MinWidth="60"/>
            <Separator/>
            <TextBlock Text="Filter:" VerticalAlignment="Center" Margin="4,0"/>
            <TextBox Text="{Binding FilterText}" Watermark="Enter filter expression..." MinWidth="300"/>
            <Button Content="Apply" Command="{Binding ApplyFilterCommand}" MinWidth="60"/>
            <Button Content="Clear Filter" Command="{Binding ClearFilterCommand}" MinWidth="80"/>
        </StackPanel>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource SystemControlBackgroundAltHighBrush}" Padding="8,4">
            <Grid ColumnDefinitions="Auto,Auto,Auto,*,Auto">
                <TextBlock Grid.Column="0" Text="{Binding StatusText}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="1" Text="{Binding StatisticsText}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="2" Text="{Binding ConversationCountText}" Margin="0,0,16,0"/>
                <TextBlock Grid.Column="4" Text="{Binding MemoryUsageText}"/>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid RowDefinitions="*,2,200">
            <!-- Traffic List -->
            <DataGrid Grid.Row="0"
                      Name="TrafficDataGrid"
                      ItemsSource="{Binding FilteredConversations}"
                      SelectedItem="{Binding SelectedConversation}"
                      IsReadOnly="True"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      GridLinesVisibility="Horizontal"
                      SelectionMode="Single">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#" Binding="{Binding Id}" Width="80"/>
                    <DataGridTextColumn Header="Method" Binding="{Binding Request.Method}" Width="80"/>
                    <DataGridTextColumn Header="Host" Binding="{Binding Host}" Width="200"/>
                    <DataGridTextColumn Header="URL" Binding="{Binding Request.Path}" Width="*"/>
                    <DataGridTextColumn Header="Status" Binding="{Binding Response.StatusCode}" Width="60"/>
                    <DataGridTextColumn Header="Size" Binding="{Binding TotalSize}" Width="80"/>
                    <DataGridTextColumn Header="Time" Binding="{Binding Duration.TotalMilliseconds, StringFormat={}{0:F0}ms}" Width="80"/>
                    <DataGridTextColumn Header="HTTPS" Binding="{Binding IsHttps}" Width="50"/>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Splitter -->
            <GridSplitter Grid.Row="1" ResizeDirection="Rows" ResizeBehavior="PreviousAndNext"/>

            <!-- Detail Panel -->
            <TabControl Grid.Row="2" SelectedIndex="{Binding SelectedDetailTab}">
                <TabItem Header="Request">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="Request Headers" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding RequestHeadersText}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="Request Body" FontWeight="Bold" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding RequestBodyText}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" MinHeight="60"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Response">
                    <ScrollViewer>
                        <StackPanel Margin="8">
                            <TextBlock Text="Response Headers" FontWeight="Bold" Margin="0,0,0,4"/>
                            <TextBox Text="{Binding ResponseHeadersText}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="12"/>
                            <TextBlock Text="Response Body" FontWeight="Bold" Margin="0,8,0,4"/>
                            <TextBox Text="{Binding ResponseBodyText}" IsReadOnly="True" AcceptsReturn="True" FontFamily="Consolas" FontSize="12" MinHeight="60"/>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                <TabItem Header="Timeline">
                    <StackPanel Margin="8">
                        <TextBlock Text="Timing Information" FontWeight="Bold" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding TimingText}" FontFamily="Consolas" FontSize="12"/>
                    </StackPanel>
                </TabItem>
            </TabControl>
        </Grid>
    </DockPanel>
</Window>
