<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:FlowReveal.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="FlowReveal.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="FlowReveal HTTP Debugger">

    <Design.DataContext>
        <vm:MainWindowViewModel/>
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,*">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="8" Margin="8" Background="{DynamicResource SystemControlBackgroundAccentBrush}">
            <Button Command="{Binding TrafficGrid.StartCaptureCommand}" 
                    IsEnabled="{Binding !TrafficGrid.IsCapturing}"
                    HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="M19 12V7H5v5h14m0 5H5v-2h14v2z"/>
                    <TextBlock Text="Start"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding TrafficGrid.StopCaptureCommand}" 
                    IsEnabled="{Binding TrafficGrid.IsCapturing}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="M6 6h12v12H6z"/>
                    <TextBlock Text="Stop"/>
                </StackPanel>
            </Button>
            <Button Command="{Binding TrafficGrid.ClearRecordsCommand}">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <PathIcon Data="M19 6H5v12h14V6zm-7 8l-4-4 1.41-1.41L12 10.17l6.59-6.59L20 4l-8 8z"/>
                    <TextBlock Text="Clear"/>
                </StackPanel>
            </Button>
            
            <Separator Height="24" Width="1" Margin="0 4"/>
            
            <TextBox Watermark="Search..." 
                     Text="{Binding TrafficGrid.SearchText, Mode=TwoWay}"
                     Width="200"/>
            
            <Separator Height="24" Width="1" Margin="0 4"/>
            
            <ComboBox PlaceholderText="Method" 
                      SelectedItem="{Binding TrafficGrid.MethodFilter, Mode=TwoWay}"
                      Width="80">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content="GET"/>
                <ComboBoxItem Content="POST"/>
                <ComboBoxItem Content="PUT"/>
                <ComboBoxItem Content="DELETE"/>
                <ComboBoxItem Content="PATCH"/>
                <ComboBoxItem Content="CONNECT"/>
            </ComboBox>
            
            <ComboBox PlaceholderText="Status" 
                      SelectedItem="{Binding TrafficGrid.StatusCodeFilter, Mode=TwoWay}"
                      Width="80">
                <ComboBoxItem Content=""/>
                <ComboBoxItem Content="1xx"/>
                <ComboBoxItem Content="2xx"/>
                <ComboBoxItem Content="3xx"/>
                <ComboBoxItem Content="4xx"/>
                <ComboBoxItem Content="5xx"/>
            </ComboBox>
        </StackPanel>

        <DataGrid Grid.Row="1"
                  ItemsSource="{Binding TrafficGrid.Records}"
                  SelectedItem="{Binding SelectedRecord, Mode=TwoWay}"
                  AutoGenerateColumns="False"
                  CanUserSortColumns="True"
                  CanUserResizeColumns="True"
                  IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" 
                                   Binding="{Binding Timestamp, StringFormat='HH:mm:ss.fff'}"
                                   Width="120"/>
                <DataGridTextColumn Header="Method" 
                                   Binding="{Binding Method}"
                                   Width="80"/>
                <DataGridTextColumn Header="URL" 
                                   Binding="{Binding Url}"
                                   Width="*"/>
                <DataGridTextColumn Header="Status" 
                                   Binding="{Binding StatusCode}"
                                   Width="70"/>
                <DataGridTextColumn Header="Time (ms)" 
                                   Binding="{Binding ResponseTimeMs}"
                                   Width="90"/>
                <DataGridTextColumn Header="Req Size" 
                                   Binding="{Binding RequestSize}"
                                   Width="90"/>
                <DataGridTextColumn Header="Res Size" 
                                   Binding="{Binding ResponseSize}"
                                   Width="90"/>
            </DataGrid.Columns>
        </DataGrid>

        <TabControl Grid.Row="2">
            <TabItem Header="Headers">
                <Grid ColumnDefinitions="*,*">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="Request Headers" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.RequestHeadersText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Grid.Column="1" RowDefinitions="Auto,*">
                        <TextBlock Text="Response Headers" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.ResponseHeadersText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Body">
                <Grid ColumnDefinitions="*,*">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="Request Body" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.RequestBodyText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Grid.Column="1" RowDefinitions="Auto,*">
                        <TextBlock Text="Response Body" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.ResponseBodyText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Raw">
                <Grid ColumnDefinitions="*,*">
                    <Grid RowDefinitions="Auto,*">
                        <TextBlock Text="Raw Request" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.RawRequest}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                    <Grid Grid.Column="1" RowDefinitions="Auto,*">
                        <TextBlock Text="Raw Response" FontWeight="Bold" Margin="4"/>
                        <TextBox Grid.Row="1" 
                                 Text="{Binding DetailPanel.RawResponse}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"/>
                    </Grid>
                </Grid>
            </TabItem>
            <TabItem Header="Timing">
                <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto">
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="DNS Lookup: " Width="120"/>
                        <TextBlock Text="{Binding DetailPanel.Record.DnsLookupTimeMs} ms"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="Connection: " Width="120"/>
                        <TextBlock Text="{Binding DetailPanel.Record.ConnectionTimeMs} ms"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="TLS Handshake: " Width="120"/>
                        <TextBlock Text="{Binding DetailPanel.Record.TlsHandshakeTimeMs} ms"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="Time to First Byte: " Width="120"/>
                        <TextBlock Text="{Binding DetailPanel.Record.TimeToFirstByteMs} ms"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="4">
                        <TextBlock Text="Total Response: " Width="120"/>
                        <TextBlock Text="{Binding DetailPanel.Record.ResponseTimeMs} ms"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>